{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "declaration": true,
    "declarationDir": "dist",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo",
    "removeComments": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "lib": [
      "dom",
      "webworker",
      "esnext"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ],
}
